# Notion Integration — BuildSafe system-of-record
# Create an integration at https://www.notion.so/my-integrations
# Share each database with your integration, then paste IDs below.

NOTION_API_KEY=secret_your_integration_token_here

# Required — worker roster synced on onboarding
NOTION_WORKERS_DATABASE_ID=your_workers_database_id

# Optional — project registry
NOTION_PROJECTS_DATABASE_ID=your_projects_database_id

# Optional — ledger audit trail (attendance, payouts, disputes)
NOTION_LEDGER_DATABASE_ID=your_ledger_database_id

# Optional — user registry on signup
NOTION_USERS_DATABASE_ID=your_users_database_id

# Optional — link to your Notion workspace (shown in UI)
NOTION_WORKSPACE_URL=https://www.notion.so/your-workspace
